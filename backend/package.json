{
  "name": "wtf-livepulse-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "test": "CI=true NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand --watchman=false",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit --runInBand",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration --runInBand"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "coveragePathIgnorePatterns": ["/node_modules/", "/tests/"],
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "!src/db/seeds/**"]
  }
}
